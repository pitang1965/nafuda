{
  "name": "nafuda-temp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && wrangler deploy --config wrangler-bundle.toml --dry-run --outdir dist/bundle && node -e \"const fs=require('fs');fs.copyFileSync('dist/bundle/worker-entry.js','dist/client/_worker.js');fs.rmSync('dist/client/wrangler.json',{force:true});fs.rmSync('.wrangler/deploy/config.json',{force:true});\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:staging": "drizzle-kit migrate --config drizzle.config.staging.ts",
    "db:migrate:prod": "drizzle-kit migrate --config drizzle.config.production.ts",
    "db:studio": "drizzle-kit studio",
    "db:studio:staging": "drizzle-kit studio --config drizzle.config.staging.ts",
    "auth:generate": "npx auth generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-start": "^1.168.18",
    "better-auth": "~1.6.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "emblor": "^1.4.8",
    "lucide-react": "^1.17.0",
    "motion": "^12.38.0",
    "posthog-js": "^1.380.1",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-image-crop": "^11.0.10",
    "react-modal-sheet": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@cloudflare/workers-types": "^4.20260603.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "workbox-build": "^7.4.0",
    "wrangler": "^4.84.1"
  }
}
