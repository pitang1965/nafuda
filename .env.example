# =============================================================================
# 環境変数リファレンス
# =============================================================================
# このファイルは「どの変数を・どこに設定するか」のドキュメントです（値はダミー）。
# コピーして使う実ファイルはすべて gitignore 対象:
#   .dev.vars / .env.local / .env.staging / .env.production
#
# 設置先の凡例:
#   [dev-runtime] ローカル開発のアプリ実行時 → .dev.vars（workerd が process.env に流す）
#   [dev-tool]    ローカルの drizzle / Vite   → .env.local
#   [migrate]     staging/prod のマイグレーション → .env.staging / .env.production（DATABASE_URL のみ）
#   [pages]       Cloudflare Pages ダッシュボード → Production / Preview（var か secret）
#   [wrangler]    wrangler.toml の [vars] / [env.preview.vars]
#
# 重要:
# - staging/prod の「アプリ実行時」の正本は [pages] ダッシュボード（このファイル群ではない）。
# - [pages] に秘密を入れ忘れたままデプロイすると src/server/auth.ts が起動時に throw し、
#   サイト全体の認証が落ちる。マージ前に必ず Preview/Production へ投入すること。
# -----------------------------------------------------------------------------

# --- サーバー実行時: 認証・DB の秘密 -----------------------------------------
# 設置先: [dev-runtime] .dev.vars ＋ [pages] に secret として（Production と Preview 両方）
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require
#   ↑ [migrate] でも必須。staging と prod は別 DB（値が異なる）。
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
FACEBOOK_CLIENT_ID=replace-me
FACEBOOK_CLIENT_SECRET=replace-me
LINE_CLIENT_ID=replace-me          # LINE Login チャンネルの Channel ID
LINE_CLIENT_SECRET=replace-me      # 同 Channel secret

# --- サーバー実行時: ベース URL ----------------------------------------------
# 設置先: [dev-runtime] .dev.vars ＋ [pages] に var として（環境ごとに実オリジン）
BETTER_AUTH_URL=http://localhost:5173   # 例) staging=https://staging.nafuda-dxn.pages.dev / prod=https://nafuda.me

# --- クライアント（ビルド時 VITE_）------------------------------------------
# 設置先: [dev-tool] .env.local。prod は auth-client.ts の fallback(https://nafuda.me) を使うため任意。
VITE_BETTER_AUTH_URL=http://localhost:5173
VITE_BASE_URL=http://localhost:5173

# --- wrangler.toml 管理（ローカルでは未設定で可）-----------------------------
# 設置先: [wrangler]（本番=[vars] / staging=[env.preview.vars]）
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev        # R2 公開バケットURL（staging/prod で別）
# VITE_REALTIME_URL=wss://nafuda-realtime.<acct>.workers.dev
# VITE_POSTHOG_KEY=phc_xxxx                     # 本番のみ有効
# VITE_POSTHOG_INTERNAL_USER_IDS=id1,id2        # 内部ユーザー(自分)の better-auth user id。is_internal:true を付与し PostHog で除外

# =============================================================================
# OAuth コールバック URL（各プロバイダのコンソールに登録）
# =============================================================================
# Google / Facebook（better-auth ビルトイン social）:
#   {BETTER_AUTH_URL}/api/auth/callback/{google|facebook}
# LINE（genericOAuth。パスに oauth2 が入る点に注意）:
#   {BETTER_AUTH_URL}/api/auth/oauth2/callback/line
#   登録する3環境（1つの LINE Login チャンネルにまとめて登録可）:
#     http://localhost:5173/api/auth/oauth2/callback/line
#     https://staging.nafuda-dxn.pages.dev/api/auth/oauth2/callback/line
#     https://nafuda.me/api/auth/oauth2/callback/line
#   ※ LINE は email 取得に「email permission」のチャンネル審査通過が前提。
